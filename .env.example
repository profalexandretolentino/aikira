# ====================================
# AIKIRA - ENVIRONMENT CONFIGURATION
# ====================================

# =========================
# DATABASE (PostgreSQL)
# =========================
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# =========================
# BACKEND (FastAPI)
# =========================
API_PORT=8000
API_HOST=0.0.0.0

# Database connection string (optional future use)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

# =========================
# FRONTEND (Next.js)
# =========================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =========================
# NODE / MONOREPO
# =========================
NODE_ENV=development